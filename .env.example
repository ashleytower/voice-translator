# Google Gemini API Key (for translation)
# Get your key at: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GOOGLE_API_KEY=your-gemini-api-key-here

# Deepgram API Key (for speech-to-text)
# Get your key at: https://console.deepgram.com/
NEXT_PUBLIC_DEEPGRAM_API_KEY=your-deepgram-api-key-here

# Cartesia API Key (for text-to-speech)
# Get your key at: https://cartesia.ai/
NEXT_PUBLIC_CARTESIA_API_KEY=your-cartesia-api-key-here

# VAPI (AI Voice Calling - server-side only, do NOT prefix with NEXT_PUBLIC)
# Get your key at: https://dashboard.vapi.ai/
VAPI_API_KEY=your-vapi-api-key-here
VAPI_PHONE_NUMBER_ID=8da70eaa-17e4-4e9d-ad53-d070833edd8b
VAPI_ASSISTANT_ID=your-assistant-id-here

# Tavily Search API (for price comparison search)
# Get your key at: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# Google Maps Platform (for Explore feature)
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Client key: restricted to Maps JavaScript API + Places API (New)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-maps-client-key-here
# Server key: restricted to Places API (New), used in API routes only
GOOGLE_MAPS_SERVER_KEY=your-maps-server-key-here

# Supabase (for auth + memory layer)
# Get your keys at: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
